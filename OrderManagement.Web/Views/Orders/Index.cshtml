<div class="container">

    <h1>Create Order</h1>

    <form id="orderForm">

        <div class="form-group">

            <label>Customer Id</label>

            <input id="customerId"
                   required />

        </div>

        <div class="form-group">

            <label>Discount Type</label>

            <select id="discountType">
                <option value="None">None</option>
                <option value="Percentage">Percentage</option>
                <option value="Fixed">Fixed</option>
            </select>

        </div>

        <table class="items-table">

            <thead>
                <tr>
                    <th>Product</th>
                    <th>Price</th>
                    <th>Qty</th>
                    <th>Total</th>
                    <th></th>
                </tr>
            </thead>

            <tbody id="itemsBody">
            </tbody>

        </table>

        <button type="button"
                id="addItemBtn"
                class="btn-primary">

            Add Item

        </button>

        <div class="summary">

            <h3>
                Sub Total :
                <span id="subTotal">0</span>
            </h3>

            <h3>
                Discount :
                <span id="discountAmount">0</span>
            </h3>

            <h2>
                Total :
                <span id="grandTotal">0</span>
            </h2>

        </div>

        <button type="submit"
                class="btn-success" id="btnSaveOrder">

            Save Order

        </button>

    </form>

</div>

<script type="module"
        src="/js/orders/create.js"></script>