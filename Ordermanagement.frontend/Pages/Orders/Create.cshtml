@page
@model OrderManagement.Frontend.Pages.Orders.CreateModel

@{
    ViewData["Title"] = "Create Order";
}

<div class="container mt-4">

    <h2>Create Order</h2>

    <div id="messageArea"></div>

    <form id="orderForm">

        <div class="mb-3">
            <label class="form-label">Customer</label>

            <select id="customerId"
                    class="form-select"
                    required>

                <option value="">Select Customer</option>

                @foreach (var customer in Model.Customers)
                {
                    <option value="@customer.Id">
                        @customer.Email
                    </option>
                }

            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">
                Discount Strategy
            </label>

            <select id="discountStrategy"
                    class="form-select">

                @foreach (var strategy in Model.DiscountStrategies)
                {
                    <option value="@strategy.Value">
                        @strategy.Name
                    </option>
                }

            </select>
        </div>

        <hr />

        <div class="d-flex justify-content-between mb-3">
            <h4>Items</h4>

            <button type="button"
                    class="btn btn-success"
                    onclick="addRow()">
                Add Item
            </button>
        </div>

        <table class="table table-bordered">

            <thead>
                <tr>
                    <th>Product Name</th>
                    <th>Product Code</th>
                    <th>Qty</th>
                    <th>Unit Price</th>
                    <th>Total</th>
                    <th></th>
                </tr>
            </thead>

            <tbody id="itemsBody">
            </tbody>

        </table>

        <div class="text-end mb-3">

            <h4>
                Grand Total:
                <span id="grandTotal">0.00</span>
            </h4>

        </div>

        <button type="submit"
                class="btn btn-primary">
            Save Order
        </button>

        <a asp-page="Index"
           class="btn btn-secondary">
            Cancel
        </a>

    </form>

</div>

@section Scripts {
    <script>

        const itemsBody =
            document.getElementById("itemsBody");

        function addRow() {

            const row =
                document.createElement("tr");

            row.innerHTML = `
                <td>
                    <input type="text"
                           class="form-control product"
                           required />
                </td>

                <td>
                    <input type="text"
                           class="form-control code"
                           required />
                </td>

                <td>
                    <input type="number"
                           class="form-control qty"
                           value="1"
                           min="1" />
                </td>

                <td>
                    <input type="number"
                           class="form-control price"
                           value="0"
                           step="0.01" />
                </td>

                <td>
                    <span class="line-total">
                        0.00
                    </span>
                </td>

                <td>
                    <button type="button"
                            class="btn btn-danger btn-sm remove">
                        X
                    </button>
                </td>
            `;

            itemsBody.appendChild(row);

            bindRow(row);

            calculateTotals();
        }

        function bindRow(row) {

            row.querySelector(".qty")
               .addEventListener("input",
                    calculateTotals);

            row.querySelector(".price")
               .addEventListener("input",
                    calculateTotals);

            row.querySelector(".remove")
               .addEventListener("click", () => {

                    row.remove();

                    calculateTotals();
               });
        }

        function calculateTotals() {

            let grandTotal = 0;

            document.querySelectorAll("#itemsBody tr")
                .forEach(row => {

                    const qty =
                        Number(
                            row.querySelector(".qty")
                               .value);

                    const price =
                        Number(
                            row.querySelector(".price")
                               .value);

                    const total =
                        qty * price;

                    row.querySelector(".line-total")
                        .innerText =
                            total.toFixed(2);

                    grandTotal += total;
                });

            document.getElementById("grandTotal")
                .innerText =
                    grandTotal.toFixed(2);
        }

       document
        .getElementById("orderForm")
        .addEventListener("submit", async function (e) {

            e.preventDefault();

            const customerId =
                document.getElementById("customerId").value;

            if (!customerId) {
                alert("Please select customer");
                return;
            }

            const items = [];

            document.querySelectorAll("#itemsBody tr")
                .forEach(row => {
                    items.push({
                        productName: row.querySelector(".product").value,
                        productCode: row.querySelector(".code").value,
                        quantity: Number(row.querySelector(".qty").value),
                        unitPrice: Number(row.querySelector(".price").value)
                    });
                });

            if (items.length === 0) {
                alert("Add at least one item");
                return;
            }

            const payload = {
                customerId: customerId,
                discountStrategy: Number(
                    document.getElementById("discountStrategy").value
                ),
                items: items
            };

            try {
                    debugger;
                 await api.createOrder(payload);

                window.location = "/Orders/Index";
            }
            catch (err) {
                document.getElementById("messageArea").innerHTML =
                    `<div class="alert alert-danger">
                        ${err.message}
                    </div>`;
            }
        });

        addRow();

    </script>

}