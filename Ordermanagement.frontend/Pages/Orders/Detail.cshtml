@page "{id:guid}"
@model OrderManagement.Frontend.Pages.Orders.DetailModel

@{
    ViewData["Title"] = "Order Details";
}

<div class="container mt-4">

    @if (Model.Order == null)
    {
        <div class="alert alert-warning">
            Order not found.
        </div>

        <a asp-page="Index" class="btn btn-secondary">
            Back
        </a>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-4">

            <h2>Order Details</h2>

            <a asp-page="Index"
               class="btn btn-secondary">
                Back to Orders
            </a>

        </div>

        <div class="card mb-4">

            <div class="card-header">
                Order Information
            </div>

            <div class="card-body">

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <strong>Order Number:</strong>
                        <br />
                        @Model.Order.OrderNumber
                    </div>

                    <div class="col-md-6 mb-3">
                        <strong>Customer:</strong>
                        <br />
                        @Model.Order.CustomerName
                    </div>

                    <div class="col-md-6 mb-3">
                        <strong>Status:</strong>
                        <br />
                        <span class="badge bg-primary">
                            @Model.Order.Status
                        </span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <strong>Created Date:</strong>
                        <br />
                        @Model.Order.OrderDate.ToString("dd/MM/yyyy HH:mm")
                    </div>

                    <div class="col-md-6 mb-3">
                        <strong>Total Amount:</strong>
                        <br />
                        @Model.Order.TotalAmount.ToString("C")
                    </div>

                </div>

            </div>

        </div>

        <div class="card">

            <div class="card-header">
                Order Items
            </div>

            <div class="card-body">

                @if (Model.Order.Items?.Any() == true)
                {
                    <table class="table table-bordered table-striped">

                        <thead>
                            <tr>
                                <th>Product Name</th>
                                <th>Product Code</th>
                                <th>Quantity</th>
                                <th>Unit Price</th>
                                <th>Total</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in Model.Order.Items)
                            {
                                <tr>

                                    <td>@item.ProductName</td>

                                    <td>@item.ProductCode</td>

                                    <td>@item.Quantity</td>

                                    <td>@item.UnitPrice.ToString("C")</td>

                                    <td>
                                        @((item.Quantity * item.UnitPrice).ToString("C"))
                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>
                }
                else
                {
                    <div class="alert alert-info">
                        No items found for this order.
                    </div>
                }

            </div>

        </div>
    }

</div>